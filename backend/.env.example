# Server Configuration
PORT=3000
NODE_ENV=development

# Database Configuration
# Get this from MongoDB Atlas: https://mongodb.com/atlas
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/docuask

# Authentication
# Generate a strong secret key (min 32 characters)
# You can generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-min-32-characters-long-here
JWT_EXPIRE=7d

# Azure Storage Configuration
# Get this from Azure Portal: https://portal.azure.com
# Navigate to your Storage Account -> Security + networking -> Access keys
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=yourstorageaccount;AccountKey=youraccountkey;EndpointSuffix=core.windows.net
AZURE_STORAGE_CONTAINER=docuask-files

# Anthropic Claude AI Configuration
# Get your API key from: https://console.anthropic.com
# Format: sk-ant-...
ANTHROPIC_API_KEY=sk-ant-your-api-key-here

# Email Configuration (Optional - for welcome & notification emails)
# Configure for Gmail, SendGrid, or your SMTP provider
# Gmail: Use App Password, not your regular password
# 1. Enable 2-Step Verification: https://myaccount.google.com/security
# 2. Create App Password: https://myaccount.google.com/apppasswords
# 3. Use the generated 16-character password below
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your-gmail@gmail.com
EMAIL_PASSWORD=your-16-char-app-password

# Optional: Frontend URL for email links
FRONTEND_URL=http://localhost:4200

# CORS Configuration (Optional)
# Comma-separated list of allowed origins
CORS_ORIGIN=http://localhost:4200,http://localhost:3000

# File Upload Configuration
MAX_FILE_SIZE=26214400
ALLOWED_FILE_TYPES=pdf
